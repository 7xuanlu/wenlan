#!/usr/bin/env bash
# agent-rigor pre-commit hook (L2).
# Generalized from a working project's .githooks/pre-commit.
#
# Job: auto-format staged source files, re-stage them so formatting can never
# reach CI, then run a fast lint scoped to the units that changed. Must be fast
# (~5s). This is a GATE: a commit with lint errors should not exist.
#
# Adapt the three TODO blocks to your toolchain. The shape (detect staged source,
# auto-format + restage, targeted lint) is the reusable part, not the commands.
set -euo pipefail

echo "Pre-commit: running fast checks..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# TODO: set your source-file extension. Examples: '\.rs$' | '\.(ts|tsx|js)$' | '\.go$' | '\.py$'
SRC_RE='\.rs$'

HAS_SRC=$(echo "$STAGED_FILES" | grep -qE "$SRC_RE" && echo "yes" || echo "no")

if [ "$HAS_SRC" = "yes" ]; then
    echo "  Auto-formatting..."
    # TODO: your formatter. Examples:
    #   cargo fmt --all | prettier --write . | gofmt -w . | ruff format .
    cargo fmt --all 2>&1

    # Re-stage anything the formatter rewrote, so it never reaches CI.
    git diff --name-only | grep -E "$SRC_RE" | xargs git add 2>/dev/null || true

    # TODO: targeted lint. Map staged paths to the changed unit(s) and lint only
    # those, so the hook stays fast. The example below lints the whole project;
    # replace with a per-unit scope if your project is large.
    #
    #   Rust:   cargo clippy -p <changed-crate> -- -D warnings
    #   Node:   npx eslint <changed-package-dir>
    #   Go:     golangci-lint run <changed-package>
    #   Python: ruff check <changed-module>
    echo "  Linting changed units..."
    cargo clippy --workspace -- -D warnings 2>&1 || {
        echo "FAIL: lint errors found. Fix before committing."
        exit 1
    }
fi

echo "Pre-commit: all checks passed."
